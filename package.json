{
  "name": "skills-manager",
  "version": "1.0.0",
  "description": "Skills Manager - 跨平台 AI Skills 管理工具",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:mac-arm64": "APPLE_SIGNING_IDENTITY=- tauri build --target aarch64-apple-darwin",
    "tauri:build:mac-x64": "APPLE_SIGNING_IDENTITY=- tauri build --target x86_64-apple-darwin",
    "tauri:build:win-x64": "tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:win-arm64": "tauri build --target aarch64-pc-windows-msvc",
    "tauri:build:linux-x64": "tauri build --target x86_64-unknown-linux-gnu",
    "tauri:build:linux-arm64": "tauri build --target aarch64-unknown-linux-gnu"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/archiver": "^6.0.3",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@types/marked": "^6.0.0",
    "marked": "^17.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
